# =============================================================================
# .env.example — Template de variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente
# NUNCA comite o arquivo .env no Git
# =============================================================================

# ── Banco de dados principal (desenvolvimento) ────────────────────────────────
DATABASE_URL=postgresql://postgres:univassouras@localhost:5432/ecommerce

# ── Banco de dados de testes (usado pelo conftest.py) ────────────────────────
# Não precisa estar no .env — o conftest.py usa esse valor como default
TEST_DATABASE_URL=postgresql://postgres:univassouras@localhost:5433/ecommerce_test

# ── Configurações da Aplicação ────────────────────────────────────────────────
APP_NAME="E-commerce API"
APP_VERSION="1.0.0"
APP_DESCRIPTION="API REST para gerenciamento de produtos de e-commerce"
DEBUG=False
